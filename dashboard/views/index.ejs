<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
    <title>GWays   ・   Giveaway bot</title>
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.gstatic.com" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="/css/style.css" />
    <script src='https://kit.fontawesome.com/a076d05399.js'></script>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <style>

      html {
        font-family: Poppins;
      }

      @media screen and (min-width:1500px) {
        .glass {
          width: 60%;
        }
        .dashboard {
          width: 60%;
          flex-direction: column;
        }
        .link {
          flex-direction: column;
        }
        .game,
        .status,
        .cards,
        .card,
        .card-info,
        .button,
        .percentage {
          width: 100%;
        }
        .circle1 {
          top: 5%;
          right: 15%;
        }
        .circle2 {
          bottom: 5%;
          left: 10%;
        }
      }

      @media screen and (max-width:1500px) {
        .glass {
          width: 60%;
        }
        .dashboard {
          width: 60%;
          flex-direction: column;
        }
        .link {
          flex-direction: column;
        }
        .game,
        .status,
        .cards,
        .card,
        .card-info,
        .button,
        .percentage {
          width: 100%;
        }
        .circle1 {
          top: 5%;
          right: 15%;
        }
        .circle2 {
          bottom: 5%;
          left: 10%;
        }
      }

      @media screen and (max-width:1450px) {
        .glass {
          width: 80%;
        }
        .dashboard {
          width: 80%;
          flex-direction: column;
        }
        .link {
          flex-direction: column;
        }
        .game,
        .status,
        .cards,
        .card,
        .button,
        .card-info,
        .percentage {
          width: 100%;
        }
        .circle1 {
          top: 5%;
          right: 15%;
        }
        .circle2 {
          bottom: 5%;
          left: 10%;
        }
      }
      
      @media screen and (max-width:1100px) {
        .user {
          width: 100%;
          flex: auto;
          flex-direction: column;
          padding-top: 50px;
        }
        .glass, 
        .dashboard,
        .game,
        .status,
        .cards,
        .card,
        .card-info,
        .percentage,
        .link,
        .button,
        .circle1,
        .circle2 { 
            width: 100%;
            flex: auto;
            flex-direction: column;
        }
        h2 {
          text-align: center;
        }
      }

      .dashText {
        color: #FFFFFF;
      }

        .button {
            background: linear-gradient(to right top, #65dfc9, #6cdbeb);
            transition: 1s;
            padding:6px 24px;
            border-radius: 6px;
            margin-top: 10px;
            width: 250px;
        }

        .button:hover {
            background: none;
        }

        .button:hover h3 {
            color: #2f3136;
        }

        .align-items {
          vertical-align: middle;
        }
    </style>
  </head>
  <body>
    <main>
      <section class="glass">
        <div class="dashboard">
          <div class="user" style="padding-top: 175px; padding-bottom: 75px;">
            <h2>GWays - The best way to manage your giveaways</h2>
            <img src="/images/banner.png" alt="" style="border-radius: 30px;padding-top: 50px;" width="500px">
          </div>
          <div class="link">
            <span class="button"><a href="https://top.gg/bot/746404171783340164/invite" target="_blank"><h3 class="dashText align-items"><span class="material-icons align-items">&#xe145;</span> Add the bot</h3></a></span>
            <span class="button"><a href="https://discord.gg/ATgdsab2k2" target="_blank"><h3 class="dashText align-items"><span class="material-icons align-items" style="font-size: 20px;">&#xe8fd;</span> Support server</h3></a></span>
            <span class="button"><a href="https://top.gg/bot/746404171783340164/vote" target="_blank"><h3 class="dashText align-items"><span class='fas fa-angle-double-up align-items' style='font-size:20px'></span></span> Vote</h3></a></span>
          </div>
        </div>
      </section>
    </main>
    <div class="circle1"></div>
    <div class="circle2"></div>
  </body>
</html>
